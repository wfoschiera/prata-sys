# Single-domain reverse proxy for prata-sys.
# Caddy listens on :80 inside the container; the host port is mapped via HOST_PORT in compose.prod.yml.
#
# Routing:
#   /api/*         -> backend (FastAPI; the OpenAPI spec is at /api/v1/openapi.json)
#   /docs, /redoc  -> backend (Swagger / ReDoc)
#   anything else  -> frontend (nginx serving the SPA)

:80 {
	encode gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'"
	}

	@backend path /api/* /docs /redoc
	handle @backend {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:80
	}
}
