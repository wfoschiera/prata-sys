# prata-sys production environment variables
# Copy to .env on the deploy host and fill in real values.
#
# IMPORTANT: Do NOT use "changethis" for any secret in staging/production —
# the app will refuse to start.

# --- App ---
ENVIRONMENT=production
PROJECT_NAME="Prata Poços"
STACK_NAME=prata-sys
SECRET_KEY=                  # generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# --- Public URL & CORS ---
# DOMAIN is informational (used in some emails/links); routing is done by Caddy.
DOMAIN=
# FRONTEND_HOST is the full URL users type in the browser, e.g. http://<host>:8080
# or https://app.example.com once you wire DNS + TLS.
FRONTEND_HOST=
BACKEND_CORS_ORIGINS=

# --- Host port for Caddy (the only port exposed by the stack) ---
HOST_PORT=8080

# --- Docker images ---
# Built by CI and pulled from GHCR; the deploy workflow overrides TAG with the
# exact commit tag (sha-xxxxxxx). These defaults also live in compose.prod.yml,
# so you can omit this whole section.
DOCKER_IMAGE_BACKEND=ghcr.io/wfoschiera/prata-sys-backend
DOCKER_IMAGE_FRONTEND=ghcr.io/wfoschiera/prata-sys-frontend
TAG=latest

# --- Database (external Postgres reachable from the deploy host) ---
# If Postgres lives on the SAME host (listening on 0.0.0.0), use host.docker.internal —
# the backend container resolves it to the host gateway via the extra_hosts mapping
# in compose.prod.yml.
POSTGRES_SERVER=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=prata_sys
POSTGRES_USER=prata_sys
POSTGRES_PASSWORD=

# --- Initial admin account (created by prestart on first boot) ---
FIRST_SUPERUSER=
FIRST_SUPERUSER_PASSWORD=

# --- SMTP (optional — leave empty to disable outbound emails) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=True
SMTP_SSL=False
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=

# --- PostHog product analytics ---
# Captured server-side by the FastAPI lifespan. Pre-filled so PostHog works
# out of the box once deployed; override POSTHOG_HOST only if you self-host.
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://us.i.posthog.com
