# prata-sys production environment variables
# Copy to /opt/prata-sys/.env and fill in real values
#
# IMPORTANT: Do NOT use "changethis" for any secret in staging/production -
# the app will refuse to start.

# --- App ---
ENVIRONMENT=staging
PROJECT_NAME="Prata Sys"
SECRET_KEY=               # generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# --- Domain & CORS ---
# Set FRONTEND_HOST to match how users access the frontend
# No DNS:   FRONTEND_HOST=http://<VPS_PUBLIC_IP>
# With DNS: FRONTEND_HOST=https://pratapocos.com.br
FRONTEND_HOST=http://CHANGE_ME
BACKEND_CORS_ORIGINS=http://CHANGE_ME

# --- Database (external PostgreSQL) ---
POSTGRES_SERVER=10.0.0.X   # private IP of the DB instance
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=          # strong password

# --- Initial admin account ---
FIRST_SUPERUSER=admin@pratapocos.com.br
FIRST_SUPERUSER_PASSWORD=   # strong password

# --- SMTP (optional - leave empty to disable emails) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=True
SMTP_SSL=False
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=

# --- Monitoring (optional) ---
SENTRY_DSN=

# --- Caddy (read by Caddy's systemd EnvironmentFile override) ---
# No DNS:   leave SITE_ADDRESS commented out (defaults to :80)
# With DNS: uncomment and set your domain
# SITE_ADDRESS=pratapocos.com.br
# DOMAIN=pratapocos.com.br
