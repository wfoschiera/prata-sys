# Local development environment — copy to .env and adjust if needed.
# Matches compose.dev.yml (Postgres + Mailpit) and native backend/frontend dev.
# Production template lives in deploy/.env.example.

ENVIRONMENT=local
PROJECT_NAME="Prata Sys"
STACK_NAME=prata-sys

DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173"

# "changethis" is allowed in local (the app only warns); real values are
# required in staging/production.
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Matches the postgres service in compose.dev.yml
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# SMTP — Mailpit from compose.dev.yml (web UI at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=False
SMTP_SSL=False
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com

SENTRY_DSN=
